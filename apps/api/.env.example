# OneFlow API environment — copy to .env for local development.
# All variables use the ONEFLOW_ prefix and are parsed by pydantic-settings
# (apps/api/app/core/config.py). Invalid values FAIL STARTUP by design.
# Changing any value requires an API restart.

# Environment: development | test | staging | production
# staging/production + ONEFLOW_AUTH_MODE=dev refuses to boot (startup guard).
ONEFLOW_ENV=development

# THE single DB entrypoint. Scheme must be postgresql+asyncpg://
# Local (host-run API + compose postgres):
ONEFLOW_DATABASE_URL=postgresql+asyncpg://oneflow:oneflow@localhost:5432/oneflow
# Inside a compose network the host would be `postgres`.
# Production values come from deployment secrets — NEVER commit them.

# pytest-only database (name MUST end with `_test`, or pytest aborts).
ONEFLOW_TEST_DATABASE_URL=postgresql+asyncpg://oneflow:oneflow@localhost:5432/oneflow_test

# Auth mode: dev | oidc
#   dev  = fixed local dev user, loopback-only (see ONEFLOW_DEV_ALLOW_NONLOCAL)
#   oidc = Authorization Code + PKCE login through the configured provider
ONEFLOW_AUTH_MODE=dev

# Dev loopback guard escape hatch. Parsing is strict: EXACTLY `true` enables it,
# anything else keeps the guard locked. Only valid in development/test —
# setting true in staging/production fails startup. Default: false.
ONEFLOW_DEV_ALLOW_NONLOCAL=false

# Optional shared password for the dev login. It is valid only in
# development/test, never returned by /auth/config or logs, and must be at
# least 12 characters when set. Strict parsing: ONLY exactly `true` below
# requires it. Changing either value requires an API restart; never commit a secret.
ONEFLOW_DEV_LOGIN_REQUIRED=false
#ONEFLOW_DEV_LOGIN_PASSWORD=replace-with-a-development-secret-of-at-least-12-characters

# Comma-separated list of allowed browser origins (each must be a valid http(s) URL).
ONEFLOW_CORS_ORIGINS=http://localhost:5173

# Log level: DEBUG | INFO | WARNING | ERROR
ONEFLOW_LOG_LEVEL=INFO

# AI summary feature flag (Phase 3 AI/RAG). Parsing is strict: EXACTLY `true`
# permits the workspace admin AI policy; anything else is a hard OFF ceiling.
# The summary uses a local, secret-free provider (no external API key). After
# setting true and restarting, an admin can enable the runtime policy at /admin/ai.
# Default: false. Changing this deployment ceiling requires a restart.
ONEFLOW_AI_SUMMARY=false

# Command palette staged rollout flag (B-030 Pass 1A). Parsing is strict:
# EXACTLY `true` exposes `command_palette_enabled=true` from /auth/config so the
# web app may render the global command palette. Anything else keeps it OFF.
# Default: false. Restart required. No settings UI: this is an operator rollout
# kill switch, not a user preference.
ONEFLOW_COMMAND_PALETTE_ENABLED=false

# --- Workspace webhook delivery (UI-42) ------------------------------------
# A legacy deployment may set only ONEFLOW_WEBHOOK_SIGNING_KEY (minimum 32
# characters); it is exposed as key ID legacy-v1. For key rotation, set the
# JSON key ring plus its active ID. Values are deployment secrets and must
# never be committed. Restart required after changes. Deploy 0064 by draining
# all pre-0064 API/worker processes before enabling a non-legacy active key;
# mixed versions retain legacy write compatibility but not pinned transport.
#ONEFLOW_WEBHOOK_SIGNING_KEY=replace-from-secret-store-minimum-32-chars
#ONEFLOW_WEBHOOK_SIGNING_KEYS={"2026-q3":"replace-from-secret-store-minimum-32-chars"}
#ONEFLOW_WEBHOOK_ACTIVE_SIGNING_KEY_ID=2026-q3
# Allowed hosts are exact comma-separated host or host:port values; arbitrary
# outbound URLs stay blocked.
# Also enforce outbound firewall/egress policy; application checks reject
# private, transition, and NAT64 addresses but are not a network boundary.
ONEFLOW_WEBHOOK_ALLOWED_HOSTS=
# Durable delivery worker bounds. These apply only when webhook delivery is enabled.
#ONEFLOW_WEBHOOK_POLL_INTERVAL_SECONDS=5
#ONEFLOW_WEBHOOK_LEASE_SECONDS=30
#ONEFLOW_WEBHOOK_MAX_ATTEMPTS=5

# Destructive seed reset token. Leave UNSET normally. To allow
# `python -m app.seed --reset` on the local non-test dev DB, set EXACTLY:
#   ONEFLOW_ALLOW_DESTRUCTIVE_RESET=local-dev-only
# (also requires local host allowlist + DB name `oneflow` + dry-run + --yes)
#ONEFLOW_ALLOW_DESTRUCTIVE_RESET=

# Connection pool tuning (PostgreSQL deployment policy first-pass variables).
ONEFLOW_DB_POOL_SIZE=10
ONEFLOW_DB_MAX_OVERFLOW=20

# --- File uploads (Pass 4 PR-M) ---------------------------------------------
# None of these are secrets. Changing any value requires an API restart.

# Blob root for uploaded attachments. The default is a LOCAL-DEV convenience
# (relative to the API working directory) — production must point at a
# dedicated, backed-up volume.
ONEFLOW_STORAGE_DIR=var/uploads

# Per-file upload cap in bytes (default 10 MiB). Enforced twice: a
# Content-Length pre-check AND authoritative streaming count.
ONEFLOW_UPLOAD_MAX_BYTES=10485760

# Per-project total stored bytes (default 1 GiB). Checked under a project
# advisory lock, so concurrent uploads cannot overshoot it.
ONEFLOW_PROJECT_STORAGE_QUOTA_BYTES=1073741824

# --- OIDC Authorization Code + PKCE ------------------------------------------
# Startup FAILS when oidc mode is selected without issuer, client credentials,
# exact callback URI, and browser origin. All URLs must use HTTPS and the web
# origin must also be present in ONEFLOW_CORS_ORIGINS. Register the exact
# redirect URI at the IdP. Restart required; there is intentionally no settings
# UI because these are deployment-level trust anchors and secrets.
#
# Provider endpoints on a host other than the issuer must be listed explicitly
# as comma-separated exact host[:port] entries. For Google this commonly needs
# oauth2.googleapis.com,www.googleapis.com; Microsoft endpoints normally share
# login.microsoftonline.com with the issuer.
# NEVER commit real values — production secrets come from deployment secrets.
# Select which visible login control owns this single OIDC trust anchor.
# Accepted values: google, microsoft, sso. Default: sso. Restart required.
# The IdP must emit a verified email claim for first-time subject binding. For
# Entra deployments, configure an equivalent verified-email claim explicitly.
#ONEFLOW_OIDC_PROVIDER=sso
#ONEFLOW_OIDC_ISSUER=https://idp.example.com/realms/company
#ONEFLOW_OIDC_CLIENT_ID=oneflow-web
#ONEFLOW_OIDC_CLIENT_SECRET=changeme-placeholder
#ONEFLOW_OIDC_REDIRECT_URI=https://api.oneflow.example.com/api/v1/auth/oidc/callback
#ONEFLOW_OIDC_WEB_ORIGIN=https://oneflow.example.com
#ONEFLOW_OIDC_ALLOWED_HOSTS=
