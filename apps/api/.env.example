# OneFlow API environment — copy to .env for local development.
# All variables use the ONEFLOW_ prefix and are parsed by pydantic-settings
# (apps/api/app/core/config.py). Invalid values FAIL STARTUP by design.
# Changing any value requires an API restart.

# Environment: development | test | staging | production
# staging/production + ONEFLOW_AUTH_MODE=dev refuses to boot (startup guard).
ONEFLOW_ENV=development

# THE single DB entrypoint. Scheme must be postgresql+asyncpg://
# Local (host-run API + compose postgres):
ONEFLOW_DATABASE_URL=postgresql+asyncpg://oneflow:oneflow@localhost:5432/oneflow
# Inside a compose network the host would be `postgres`.
# Production values come from deployment secrets — NEVER commit them.

# pytest-only database (name MUST end with `_test`, or pytest aborts).
ONEFLOW_TEST_DATABASE_URL=postgresql+asyncpg://oneflow:oneflow@localhost:5432/oneflow_test

# Auth mode: dev | oidc
#   dev  = fixed local dev user, loopback-only (see ONEFLOW_DEV_ALLOW_NONLOCAL)
#   oidc = not implemented yet → all requests 501
ONEFLOW_AUTH_MODE=dev

# Dev loopback guard escape hatch. Parsing is strict: EXACTLY `true` enables it,
# anything else keeps the guard locked. Only valid in development/test —
# setting true in staging/production fails startup. Default: false.
ONEFLOW_DEV_ALLOW_NONLOCAL=false

# Comma-separated list of allowed browser origins (each must be a valid http(s) URL).
ONEFLOW_CORS_ORIGINS=http://localhost:5173

# Log level: DEBUG | INFO | WARNING | ERROR
ONEFLOW_LOG_LEVEL=INFO

# AI summary feature flag (Phase 3 AI/RAG). Parsing is strict: EXACTLY `true`
# enables the work-package summary endpoint + its UI button; anything else keeps
# it OFF. The summary uses a local, secret-free provider (no external API key).
# Default: false. No restart-safe UI toggle — operator sets this at deploy time.
ONEFLOW_AI_SUMMARY=false

# Destructive seed reset token. Leave UNSET normally. To allow
# `python -m app.seed --reset` on the local non-test dev DB, set EXACTLY:
#   ONEFLOW_ALLOW_DESTRUCTIVE_RESET=local-dev-only
# (also requires local host allowlist + DB name `oneflow` + dry-run + --yes)
#ONEFLOW_ALLOW_DESTRUCTIVE_RESET=

# Connection pool tuning (PostgreSQL deployment policy first-pass variables).
ONEFLOW_DB_POOL_SIZE=10
ONEFLOW_DB_MAX_OVERFLOW=20
