# OneFlow root env example — Docker Compose bootstrap variables ONLY.
# Copy to .env for local development. Never commit real secrets.
# App-level settings live in apps/api/.env.example and apps/web/.env.example.

# Local PostgreSQL container bootstrap (compose.yaml).
# These are LOCAL-ONLY example values, not production secrets.
POSTGRES_DB=oneflow
POSTGRES_USER=oneflow
POSTGRES_PASSWORD=oneflow

# Host port mapping for the postgres service. Change if 5432 is taken.
# Restart `docker compose up -d postgres` after changing.
ONEFLOW_POSTGRES_PORT=5432

# Dev-login sessions (Pass 72 / UI-110). Default false = the historical
# zero-credential auto dev user (cookies ignored — deterministic for tests/scripts).
# EXACTLY "true" (strict parse) requires both a session cookie and a shared
# development password of at least 12 characters. Configure the password only
# in apps/api/.env or a secret store; never commit it. Restart required to
# change. Not exposed in settings UI because this is boot-time auth policy.
#ONEFLOW_DEV_LOGIN_REQUIRED=false
#ONEFLOW_DEV_LOGIN_PASSWORD=replace-with-a-development-secret-of-at-least-12-characters
